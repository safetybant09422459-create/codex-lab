{
  "id": "get_experience_photos",
  "skill_id": "travel",
  "name": "Get Experience Photos",
  "description": "Get photo candidates for a travel experience by delegating to the Photo skill boundary.",
  "status": "implemented",
  "mode": "read",
  "risk_level": "medium",
  "confirmation_required": false,
  "audit_required": true,
  "input_schema": {
    "type": "object",
    "properties": {
      "experience_id": {
        "type": "string",
        "description": "Travel experience id"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 50
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "default": 0
      }
    },
    "required": ["experience_id"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "experience_id": {
        "type": "string"
      },
      "experience_type": {
        "type": "string"
      },
      "timeline_item_id": {
        "type": "string"
      },
      "trip_id": {
        "type": "string"
      },
      "photos": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "pagination": {
        "type": "object"
      },
      "source": {
        "type": "string",
        "const": "photo_skill"
      }
    },
    "required": [
      "experience_id",
      "experience_type",
      "timeline_item_id",
      "trip_id",
      "photos",
      "pagination",
      "source"
    ]
  }
}

{
  "id": "set_trip_cover_image",
  "skill_id": "travel",
  "name": "Set Trip Cover Image",
  "description": "Set a Photo Skill asset as the representative cover image for a trip.",
  "status": "implemented",
  "mode": "write",
  "risk_level": "medium",
  "confirmation_required": true,
  "audit_required": true,
  "input_schema": {
    "type": "object",
    "properties": {
      "trip_id": {
        "type": "string",

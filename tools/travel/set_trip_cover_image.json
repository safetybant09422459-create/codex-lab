        "description": "Trip id"
      },
      "asset_id": {
        "type": "string",
        "minLength": 1,
        "description": "Photo Skill asset id"
      }
    },
    "required": ["trip_id", "asset_id"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "trip_id": {
        "type": "string"
      },
      "cover_image_id": {
        "type": "string"
      },
      "asset_id": {
        "type": "string"
      },
      "thumbnail_url": {
        "type": "string",
        "format": "uri-reference"
      },
      "source": {
        "type": "string",
        "const": "local_travel_write"
      }
    },
    "required": [
      "trip_id",
      "cover_image_id",
      "asset_id",
      "thumbnail_url",
      "source"
    ]
  }

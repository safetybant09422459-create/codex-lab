{
  "id": "get_experience_photo_links",
  "skill_id": "travel",
  "name": "Get Experience Photo Links",
  "description": "Get active photo links explicitly attached to a Travel Experience.",
  "status": "implemented",
  "mode": "read",
  "risk_level": "medium",
  "confirmation_required": false,
  "audit_required": true,
  "input_schema": {
    "type": "object",
    "properties": {
      "experience_id": {
        "type": "string",
        "minLength": 1,
        "description": "Travel experience id."
      },
      "status": {
        "type": "string",
        "enum": ["active", "archived"],
        "default": "active"
      }
    },
    "required": ["experience_id"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "experience_id": {
        "type": "string"
      },
      "timeline_item_id": {
        "type": "string"
      },
      "trip_id": {
        "type": "string"
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "count": {
        "type": "integer"
      },
      "source": {
        "type": "string",
        "const": "local_travel_read"
      }
    },
    "required": ["experience_id", "links", "count", "source"]
  }
}

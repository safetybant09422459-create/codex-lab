{
  "id": "get_experience_photo_search",
  "skill_id": "travel",
  "name": "Search Experience Photos",
  "description": "Search photos in an explicit date-time range for linking to a travel experience through the Photo skill boundary.",
  "status": "implemented",
  "mode": "read",
  "risk_level": "medium",
  "confirmation_required": false,
  "audit_required": true,
  "input_schema": {
    "type": "object",
    "properties": {
      "experience_id": {"type": "string"},
      "from": {"type": "string", "description": "ISO8601 range start with timezone"},
      "to": {"type": "string", "description": "ISO8601 range end with timezone"},
      "limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 50},
      "offset": {"type": "integer", "minimum": 0, "default": 0}
    },
    "required": ["experience_id", "from", "to"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "experience_id": {"type": "string"},
      "experience_type": {"type": "string"},
      "timeline_item_id": {"type": "string"},
      "trip_id": {"type": "string"},
      "from": {"type": "string"},
      "to": {"type": "string"},
      "photos": {"type": "array", "items": {"type": "object"}},
      "pagination": {"type": "object"},
      "source": {"type": "string", "const": "photo_skill"}
    },
    "required": ["experience_id", "photos", "pagination", "source"]
  }
}
